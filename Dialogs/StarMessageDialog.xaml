<Window x:Class="Notari.Dialogs.StarMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
        Title="Hey!"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource Brush.Surface}"
        Foreground="{StaticResource Brush.TextPrimary}"
        FontFamily="{StaticResource Font.Primary}"
        FontSize="{StaticResource FontSize.Base}">

    <StackPanel Margin="24">

        <!-- Icon + message -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <ui:SymbolIcon Symbol="StarEmphasis"
                           Foreground="{StaticResource Brush.Accent}"
                           FontSize="28"
                           VerticalAlignment="Center"
                           Margin="0,2,14,0"/>
            <StackPanel>
                <TextBlock Text="If you end up liking Notari, a star on"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           TextWrapping="Wrap"/>
                <TextBlock Text="GitHub helps a lot :) Enjoy using it!"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="BtnOk"
                    Content="Get started"
                    Width="110"
                    Style="{StaticResource Style.Button.Accent}"
                    Click="OnOk"/>
        </StackPanel>
    </StackPanel>
</Window>
