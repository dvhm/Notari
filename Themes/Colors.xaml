<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Surfaces -->
    <Color x:Key="Color.Background">#FF121212</Color>
    <Color x:Key="Color.Surface">#FF1E1E1E</Color>
    <Color x:Key="Color.SurfaceElevated">#FF2A2A2A</Color>

    <!-- Text -->
    <Color x:Key="Color.TextPrimary">#FFFFFFFF</Color>
    <Color x:Key="Color.TextSecondary">#B3FFFFFF</Color>
    <Color x:Key="Color.TextDisabled">#66FFFFFF</Color>

    <!-- Brand -->
    <Color x:Key="Color.Primary">#FF4FC3F7</Color>
    <Color x:Key="Color.PrimaryHover">#FF81D4FA</Color>
    <Color x:Key="Color.Accent">#FFFFC107</Color>

    <!-- Semantic -->
    <Color x:Key="Color.Success">#FF4CAF50</Color>
    <Color x:Key="Color.Warning">#FFFFA000</Color>
    <Color x:Key="Color.Error">#FFEF5350</Color>
    <Color x:Key="Color.Highlight">#66C084FC</Color>
    <Color x:Key="Color.Dim">#881E1E1E</Color>
    <Color x:Key="Color.FindMatch">#33FFFFFF</Color>
    <Color x:Key="Color.FindMatchActive">#66FFFFFF</Color>

    <!-- Chrome -->
    <Color x:Key="Color.Border">#33FFFFFF</Color>
    <Color x:Key="Color.Divider">#1FFFFFFF</Color>
    <Color x:Key="Color.Shadow">#FF000000</Color>

    <!-- Accent swatches — single source of truth for the settings color picker -->
    <Color x:Key="Color.Swatch.Blue">  #FF4FC3F7</Color>
    <Color x:Key="Color.Swatch.Purple">#FFB07EFC</Color>
    <Color x:Key="Color.Swatch.Pink">  #FFFC7EC8</Color>
    <Color x:Key="Color.Swatch.Red">   #FFEF5350</Color>
    <Color x:Key="Color.Swatch.Orange">#FFFFA040</Color>
    <Color x:Key="Color.Swatch.Yellow">#FFFFC107</Color>
    <Color x:Key="Color.Swatch.Green"> #FF4CAF50</Color>
    <Color x:Key="Color.Swatch.Cyan">  #FF26C6DA</Color>

    <!-- Rhyme-scheme badge palette — one hue per letter A–J, cycling after 10 -->
    <Color x:Key="Color.Rhyme.A">#FF4FC3F7</Color>
    <Color x:Key="Color.Rhyme.B">#FF81C784</Color>
    <Color x:Key="Color.Rhyme.C">#FFFFB74D</Color>
    <Color x:Key="Color.Rhyme.D">#FFCE93D8</Color>
    <Color x:Key="Color.Rhyme.E">#FFEF8389</Color>
    <Color x:Key="Color.Rhyme.F">#FF4DD0E1</Color>
    <Color x:Key="Color.Rhyme.G">#FFF06292</Color>
    <Color x:Key="Color.Rhyme.H">#FFDCE775</Color>
    <Color x:Key="Color.Rhyme.I">#FF7986CB</Color>
    <Color x:Key="Color.Rhyme.J">#FFFF8A65</Color>

</ResourceDictionary>