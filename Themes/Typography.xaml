<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Families -->
    <FontFamily x:Key="Font.Primary">Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Mono">Cascadia Code, Consolas, Courier New</FontFamily>

    <!-- Sizes -->
    <sys:Double x:Key="FontSize.XSmall">10</sys:Double>
    <sys:Double x:Key="FontSize.Small">12</sys:Double>
    <sys:Double x:Key="FontSize.Base">14</sys:Double>
    <sys:Double x:Key="FontSize.Medium">16</sys:Double>
    <sys:Double x:Key="FontSize.Large">20</sys:Double>
    <sys:Double x:Key="FontSize.XLarge">24</sys:Double>
    <sys:Double x:Key="FontSize.Display">32</sys:Double>

    <!-- Weights -->
    <FontWeight x:Key="FontWeight.Regular">Regular</FontWeight>
    <FontWeight x:Key="FontWeight.Medium">Medium</FontWeight>
    <FontWeight x:Key="FontWeight.SemiBold">SemiBold</FontWeight>
    <FontWeight x:Key="FontWeight.Bold">Bold</FontWeight>

</ResourceDictionary>
